HOST=0.0.0.0
PORT=8080
# Optional: if omitted, server auto-generates/persists these tokens in secrets.json.
# PHONE_API_TOKEN=replace-with-long-random-token
# AGENT_BOOTSTRAP_TOKEN=replace-with-bootstrap-token
# Optional: where auto-generated tokens are persisted.
# SECRETS_PATH=./data/secrets.json
PUBLIC_WS_URL=wss://your-domain.example/ws/agent
# Optional external client URL (for pairing link generation).
PWA_PUBLIC_URL=https://pclaystation.github.io/Jarvis/
SQLITE_PATH=./data/jarvis.db
COMMAND_TIMEOUT_MS=5000
MAX_PENDING_COMMANDS=1000
HEARTBEAT_TTL_MS=90000
WS_AUTH_TIMEOUT_MS=10000
WS_PING_INTERVAL_MS=30000
WS_MAX_MESSAGE_BYTES=65536
CORS_ALLOWED_ORIGINS=https://pclaystation.github.io,https://mpmc.ddns.net
